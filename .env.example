# Copy to .env and fill with your values.
# Get verifyAppleSubscription URL after: firebase deploy --only functions
CLOUD_FUNCTION_URL=https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net/verifyAppleSubscription
# App Store Connect → In-App Purchases (auto-renewable subscription product IDs)
IAP_PRODUCT_MONTHLY=com.yourapp.premium.monthly
IAP_PRODUCT_YEARLY=com.yourapp.premium.yearly
PRIVACY_POLICY_URL=https://yoursite.com/privacy
